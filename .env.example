APP_MODE=local
PUBLIC_WEB_URL=http://localhost:8080
PUBLIC_API_URL=http://localhost:8080
INTERNAL_API_URL=http://api:4000
DATABASE_URL=postgres://twitch_tracker:twitch_tracker@postgres:5432/twitch_tracker
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/twitch/callback
# Current user login only needs identity; keep this blank unless a feature needs extra user scopes.
TWITCH_LOGIN_SCOPES=
TWITCH_EVENTSUB_SECRET=replace-with-at-least-32-random-characters
# Keep false for plain localhost. Real Twitch EventSub webhooks need public HTTPS on port 443.
EVENTSUB_ENABLED=false
EVENTSUB_MAX_CHANNELS=25
TWITCH_BOT_OAUTH_REDIRECT_URI=http://localhost:8080/api/internal/bot-accounts/oauth/callback
# Bot IRC reading and future moderator-aware chat APIs.
TWITCH_BOT_SCOPES=chat:read user:read:chat user:read:moderated_channels moderator:read:chatters
TWITCH_BOT_USER_ID=
TWITCH_BOT_LOGIN=
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
ADMIN_TWITCH_USER_IDS=
ENABLE_TWITCH_INGESTION=false
DEFAULT_BOT_JOIN_CAPACITY=100
DEFAULT_BOT_JOIN_RATE_PER_10_SECONDS=20
# Stream discovery stores viewer snapshots. 180000 keeps MVP storage/query volume sane; lower for short local tests.
DISCOVERY_INTERVAL_MS=180000
USER_HYDRATION_INTERVAL_MS=300000
ASSIGNMENT_INTERVAL_MS=30000
CHATTERS_RECONCILIATION_INTERVAL_MS=300000
CHATTERS_RECONCILIATION_MAX_CHANNELS=25
CHATTERS_RECONCILIATION_MAX_PAGES_PER_CHANNEL=5
AGGREGATION_INTERVAL_MS=60000
AGGREGATION_BUCKET_MINUTES=5
AGGREGATION_LOOKBACK_HOURS=48
MAINTENANCE_INTERVAL_MS=300000
RAW_CHAT_RETENTION_DAYS=30
RAW_PAYLOAD_RETENTION_DAYS=30
STALE_ASSIGNMENT_GRACE_MINUTES=15
BACKUP_RETENTION_DAYS=14
