EVENTSUB_MAX_CHANNELS=25
TWITCH_BOT_USER_ID=
TWITCH_BOT_LOGIN=
TWITCH_BOT_ACCESS_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
